{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["vite/client"]
  },
  "include": ["src/components/**/*.js", "src/pages/**/*.jsx", "src/contexts/**/*.jsx", "src/hooks/**/*.jsx", "src/App.jsx"],
  "exclude": ["node_modules", "dist", "src/components/ui", "src/api", "src/lib", "src/config", "src/middleware", "src/services", "src/types"]
} 
